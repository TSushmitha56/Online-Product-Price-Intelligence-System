# ─── Backend Docker ignore ────────────────────────────────────────────────────
# Prevent secrets, dev artifacts, and large unnecessary files
# from being copied into the Docker build context.

# Environment files (never copy secrets into images)
.env
.env.*
!.env.example

# Virtual environments
venv/
.venv/
env/
ENV/
dt_venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.log

# SQLite dev database
db.sqlite3
price_intel.db

# Media uploads (served via volume in production)
media/

# Static files (generated by collectstatic)
staticfiles/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Documentation (not needed at runtime)
docs/
*.md
!requirements.txt

# Test files
test_*.py
tests/
*_test.py

# Build artifacts
dist/
build/
