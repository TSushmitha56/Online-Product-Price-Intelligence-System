# ─── PriceIntel Backend — PRODUCTION Environment Variables ────────────────────
# Copy to .env.production and fill in ALL values before deployment.
# This file is gitignored. NEVER commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
DEBUG=False
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=REPLACE_WITH_A_50_CHAR_RANDOM_SECRET_KEY
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname
# In Docker Compose, host is the service name 'db'
DATABASE_URL=postgres://priceintel_user:STRONG_DB_PASSWORD@db:5432/priceintel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
# For Gmail, use an App Password (not your account password)
EMAIL_HOST_PASSWORD=YOUR_APP_PASSWORD_HERE
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# ── Frontend URL (for password reset emails) ──────────────────────────────────
FRONTEND_URL=https://your-domain.com

# ── Third-Party API Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=
SERPAPI_API_KEY=
SCRAPINGBEE_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=WARNING

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=10485760

# ── PostgreSQL Docker env vars (used by docker-compose.yml) ──────────────────
POSTGRES_DB=priceintel
POSTGRES_USER=priceintel_user
POSTGRES_PASSWORD=STRONG_DB_PASSWORD
