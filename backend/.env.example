# ─── PriceIntel Backend Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use SQLite (dev default)
# Set to a Postgres DSN for production, e.g.:
#   postgres://user:password@localhost:5432/priceintel
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of trusted frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Email ─────────────────────────────────────────────────────────────────────
# For development, keep this as console backend (prints to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@priceintel.dev

# ── Third-Party API Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=
SERPAPI_API_KEY=
SCRAPINGBEE_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO

# ── Upload Limits ─────────────────────────────────────────────────────────────
# Max file size in bytes (default: 10MB = 10485760)
MAX_UPLOAD_SIZE=10485760
